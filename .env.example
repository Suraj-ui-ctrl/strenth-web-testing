# â”€â”€ App â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
APP_NAME="BOM Agent System"
DEBUG=false
SECRET_KEY=change-me-to-a-long-random-string

# â”€â”€ PostgreSQL â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=bom_user
POSTGRES_PASSWORD=bom_password
POSTGRES_DB=bom_db
# Flask BOM Tool uses DATABASE_URL when set. Leave blank for local SQLite fallback.
# Alternative: set DB_BACKEND=postgres and POSTGRES_* values below.
DB_BACKEND=sqlite
DATABASE_URL=postgresql://bom_user:bom_password@localhost:5432/bom_db

# â”€â”€ Redis â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# â”€â”€ Storage: local or s3 â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
STORAGE_BACKEND=local
LOCAL_UPLOAD_DIR=uploads

# For S3:
# STORAGE_BACKEND=s3
# AWS_S3_BUCKET=your-bucket-name
# AWS_ACCESS_KEY_ID=your-access-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-access-key
# AWS_REGION=us-east-1

# â”€â”€ LLM provider â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Set LLM_PROVIDER to: anthropic | openai | gemini | hermes
LLM_PROVIDER=anthropic
LLM_MODEL=

# Paste Claude/Anthropic key here:
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Smart mode uses local rules first, then one cheap model, and asks other models only
# when confidence is low or providers disagree. Set "all" only for critical audits.
AI_COMPARE_MODE=smart
AI_MAX_COMPONENTS_PER_LLM_BATCH=25

# Hidden Cybex customs-duty verification. Keep product search off by default
# because Cybex product-name pages can be slow; HSN page verification still runs.
CYBEX_TIMEOUT_SECONDS=8
CYBEX_CACHE_TTL_SECONDS=86400
CYBEX_PRODUCT_SEARCH=false

# For OpenAI:
# LLM_PROVIDER=openai
OPENAI_API_KEY=

# For Gemini:
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# For local Hermes (via Ollama):
# LLM_PROVIDER=hermes
# HERMES_BASE_URL=http://localhost:11434/v1
# HERMES_MODEL=hermes3

# Alternatives: false = fast LLM/description mode, true = slower datasheet PDF analysis.
ALT_USE_DATASHEET_AI=false

# â”€â”€ Classifier â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
CLASSIFIER_CONFIDENCE_THRESHOLD=0.75

# â”€â”€ Supplier APIs (carried from existing system) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
MOUSER_API_KEY=
DIGIKEY_CLIENT_ID=
DIGIKEY_CLIENT_SECRET=
ELEMENT14_API_KEY=
LCSC_USD_TO_INR=83.5
LCSC_LANDED_MULTIPLIER=1.5
OVERSEAS_LANDED_MULTIPLIER=1.5
REQUEST_TIMEOUT_SECONDS=4
VENDOR_DISCOVERY_TIMEOUT_SECONDS=6
VENDOR_CACHE_TTL_SECONDS=3600

# â”€â”€ Google APIs (Drive/search/etc.) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
GOOGLE_API_KEY=

# â”€â”€ Email â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
EMAIL_ADDRESS=
EMAIL_PASSWORD=

